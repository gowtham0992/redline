{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.gowtham0992/redline",
  "title": "redline",
  "description": "Run local prompt regression checks from prompt-response logs in AI coding assistants.",
  "websiteUrl": "https://gowtham0992.github.io/redline/",
  "repository": {
    "url": "https://github.com/gowtham0992/redline",
    "source": "github"
  },
  "version": "0.2.0",
  "packages": [
    {
      "registryType": "pypi",
      "registryBaseUrl": "https://pypi.org",
      "identifier": "redline-ai",
      "version": "0.2.0",
      "runtimeHint": "uvx",
      "runtimeArguments": [
        {
          "type": "named",
          "name": "--from",
          "value": "redline-ai==0.2.0",
          "description": "Install the redline-ai package version that matches this registry entry."
        },
        {
          "type": "positional",
          "value": "redline-mcp",
          "description": "Run the redline MCP stdio entrypoint."
        }
      ],
      "transport": {
        "type": "stdio"
      }
    }
  ]
}
